{
  "name": "agavia-products-ms",
  "version": "1.0.0",
  "description": "Products microservice for AGAVIA conversational system",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:dev": "ts-node src/server.ts",
    "postinstall": "prisma generate",
    "dev": "ts-node src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "echo '❌ DO NOT RUN MIGRATIONS IN PRODUCTION'",
    "test:tool": "curl -X POST http://localhost:3000/execute -H 'Content-Type: application/json' -d '{\"tool\":\"create_product_from_chat\",\"businessId\":\"test\",\"args\":{\"title\":\"Test\",\"price\":100}}'"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
